# Copy to .env and adjust. docker compose reads this file automatically;
# for local `task run`, export what you need.

# --- API (read by the app) ---------------------------------------------------
HTTP_ADDR=:8080
LOG_LEVEL=info            # debug | info | warn | error
GIN_MODE=release          # release | debug | test
SAGA_STEP_TIMEOUT=5m      # fail saga steps with no progress for this long (0 disables)

# BROKER_URL switches the service-bus transport: empty → in-process
# GoChannel (dev/tests); an AMQP URL → RabbitMQ with durable queues
# (production; the compose stack sets it automatically).
BROKER_URL=amqp://guest:guest@localhost:5672/

# AUTH_ISSUER switches authentication: empty → open API (dev/tests); an
# OIDC issuer → bearer tokens + RBAC (the compose stack points these at
# Keycloak: realm brewup, users manager/operator/barfly, password brewup).
AUTH_ISSUER=http://localhost:8180/realms/brewup
AUTH_JWKS_URL=http://localhost:8180/realms/brewup/protocol/openid-connect/certs
AUTH_CLIENT_ID=brewup-api

# --- Database ------------------------------------------------------------------
# DB_URL switches persistence: empty → everything in memory (dev/tests);
# a Postgres URL → durable event store + read models (production; the
# compose stack sets it automatically).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beer
DB_USER=beer
DB_PASSWORD=beerpassword
DB_URL=postgres://beer:beerpassword@localhost:5432/beer?sslmode=disable

# --- Atlas migrations ----------------------------------------------------------
ATLAS_DIR=migrations
ATLAS_DB_URL=postgres://beer:beerpassword@localhost:5432/beer?sslmode=disable

# --- Operability -----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=   # set to e.g. http://otel-collector:4318 to export traces
OTEL_SERVICE_NAME=cj-beer-company
RATE_LIMIT_RPS=50              # per-client-IP requests/second (0 disables)
RATE_LIMIT_BURST=100
MAX_BODY_BYTES=1048576         # request body cap (0 disables)


# Copy to .env and adjust. docker compose reads this file automatically;
# for local `task run`, export what you need.

# --- API (read by the app) ---------------------------------------------------
HTTP_ADDR=:8080
LOG_LEVEL=info            # debug | info | warn | error
GIN_MODE=release          # release | debug | test

# --- Database ------------------------------------------------------------------
# DB_URL switches persistence: empty → everything in memory (dev/tests);
# a Postgres URL → durable event store + read models (production; the
# compose stack sets it automatically).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beer
DB_USER=beer
DB_PASSWORD=beerpassword
DB_URL=postgres://beer:beerpassword@localhost:5432/beer?sslmode=disable

# --- Atlas migrations ----------------------------------------------------------
ATLAS_DIR=migrations
ATLAS_DB_URL=postgres://beer:beerpassword@localhost:5432/beer?sslmode=disable
